# PostHog private API key (Bearer token for server-side queries)
POSTHOG_API_KEY=phx_your_private_key_here

# PostHog API host
POSTHOG_HOST=https://us.posthog.com

# Comma-separated PostHog project IDs to aggregate metrics from
POSTHOG_PROJECT_IDS=12345,67890

# Comma-separated domain patterns for private projects (hidden behind "Apps de particulares")
PRIVATE_DOMAIN_PATTERNS=my-secret-app,another-private

# PostHog public key for client-side analytics (write-only, safe for public use)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_public_key_here

# PostHog ingest host for client-side analytics
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
